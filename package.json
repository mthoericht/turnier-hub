{
  "name": "turnier-hub",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "rimraf node_modules client/node_modules server/node_modules client/dist server/dist",
    "clean:install": "npm run clean && npm install",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v",
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w @turnier-hub/shared && npm run build -w server && npm run build -w client",
    "lint": "npm run lint -w client",
    "lint:fix": "npm run lint:fix -w client",
    "prod:prepare": "npm run db:generate -w server && npm run build",
    "prod:start": "NODE_ENV=production npm run start:prod -w server",
    "prod": "npm run prod:prepare && npm run prod:start",
    "db:push": "npm run db:push -w server",
    "db:push:test": "npm run db:push:test -w server",
    "db:migrate": "npm run db:migrate -w server --",
    "db:migrate:test": "npm run db:migrate:test -w server",
    "db:deploy": "npm run db:deploy -w server",
    "db:studio": "npm run db:studio -w server",
    "dev:test": "npm run dev:test -w server",
    "db:generate": "npm run db:generate -w server",
    "db:seed": "npm run db:seed -w server",
    "db:clear": "npm run db:clear -w server --",
    "db:clear:test": "npm run db:clear:test -w server --",
    "test": "npm run test -w server && npm run test -w client",
    "test:client": "npm run test -w client",
    "test:unit": "npm run test:unit -w server",
    "test:integration": "npm run test:prepare -w server && npm run test:integration -w client",
    "security:audit": "node ./scripts/security-audit.mjs",
    "storybook": "npm run storybook -w client",
    "build-storybook": "npm run build-storybook -w client"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "rimraf": "^6.0.1"
  }
}
