# Testumgebung (lokal / CI): eigene MySQL-Datenbank, anderer Port als Dev.
# Schema anlegen: npm run db:push:test (Repo-Root) oder: npm run db:push:test -w server
# Server: npm run dev:test — bei parallelem Vite ggf. client/vite.config.ts proxy auf PORT 3002 legen.
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=turnier_user
DB_PASSWORD=turnier_pass
DB_NAME=turnier-hub-test
PORT=3002
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
TRUST_PROXY=false
JSON_BODY_LIMIT="100kb"
