# Testumgebung (lokal / CI): eigene SQLite-Datei, anderer Port als Dev.
# Schema anlegen: npm run db:push:test (Repo-Root) oder: npm run db:push:test -w server
# Server: npm run dev:test — bei parallelem Vite ggf. client/vite.config.ts proxy auf PORT 3002 legen.
DATABASE_URL="file:../../data/test.db"
JWT_SECRET="test-only-turnier-hub-jwt-secret-do-not-use-in-prod"
INVITE_CODE="ballspiele2026"
PORT=3002
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
TRUST_PROXY=false
JSON_BODY_LIMIT="100kb"
