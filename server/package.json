{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:test": "NODE_ENV=test tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "prod:prepare": "prisma generate && npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma migrate deploy",
    "db:push:test": "dotenv -e .env.test -- prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:migrate:test": "dotenv -e .env.test -- prisma migrate deploy",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:seed:test": "dotenv -e .env.test -- prisma db seed",
    "db:clear": "tsx scripts/clearDbExceptUsers.ts",
    "db:clear:test": "dotenv -e .env.test -- tsx scripts/clearDbExceptUsers.ts",
    "test": "NODE_ENV=test dotenv -e .env.test -- vitest run",
    "test:watch": "NODE_ENV=test dotenv -e .env.test -- vitest",
    "test:unit": "NODE_ENV=test dotenv -e .env.test -- vitest run ../tests/server/unit",
    "test:integration": "NODE_ENV=test dotenv -e .env.test -- vitest run ../tests/server/integration --passWithNoTests",
    "test:prepare": "dotenv -e .env.test -- prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@turnier-hub/shared": "file:../shared",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.5",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.19.3",
    "supertest": "^7.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
