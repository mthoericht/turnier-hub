# Entwicklung: .env (nicht committen). Test: .env.test + npm run dev:test / db:push:test.
# Postgres läuft via `npm run docker:up` aus dem Repo-Root (siehe docker-compose.yml).
DATABASE_URL="postgresql://turnier:turnier@localhost:5432/turnier_dev?schema=public"
JWT_SECRET="change-me-in-production"
INVITE_CODE="ballspiele2026"
DEFAULT_SCHOOL_NAME="defaultSchool"
PORT=3001
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_LOGIN_MAX_REQUESTS=20
AUTH_SIGNUP_MAX_REQUESTS=10
AUTH_IDENTIFIER_MAX_REQUESTS=10
LOGIN_LOCKOUT_START_AFTER_FAILURES=3
LOGIN_LOCKOUT_BASE_MS=15000
LOGIN_LOCKOUT_MAX_MS=900000
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
TRUST_PROXY=false
JSON_BODY_LIMIT="100kb"
# WS_*- und SECURITY_WS_*-Werte werden in Phase 2 gemeinsam mit dem WebSocket-Hub
# entfernt; bis dahin bleiben sie hier dokumentiert.
WS_CONNECT_WINDOW_MS=60000
WS_CONNECT_MAX_PER_IP=30
WS_MESSAGE_WINDOW_MS=10000
WS_MESSAGE_MAX_PER_WINDOW=120
WS_MAX_SUBSCRIPTIONS_PER_CLIENT=50
SECURITY_HTTP_STATUS_WINDOW_MS=60000
SECURITY_HTTP_STATUS_THRESHOLD=50
SECURITY_WS_CONNECTIONS_WINDOW_MS=60000
SECURITY_WS_CONNECTIONS_THRESHOLD=100
