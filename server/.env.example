# Local development defaults (PostgreSQL on localhost).
# Test profile uses `server/.env.test` with `turnier_test`.
DATABASE_URL="postgresql://turnier:turnier@localhost:5432/turnier_dev?schema=public"
JWT_SECRET="change-me-in-production"
INVITE_CODE="ballspiele2026"
DEFAULT_SCHOOL_NAME="defaultSchool"
PORT=3001
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_LOGIN_MAX_REQUESTS=20
AUTH_SIGNUP_MAX_REQUESTS=10
AUTH_IDENTIFIER_MAX_REQUESTS=10
LOGIN_LOCKOUT_START_AFTER_FAILURES=3
LOGIN_LOCKOUT_BASE_MS=15000
LOGIN_LOCKOUT_MAX_MS=900000
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
TRUST_PROXY=false
JSON_BODY_LIMIT="100kb"

# Runtime adapters:
# - local single-process: memory
# - AWS multi-instance: dynamo
RATE_LIMIT_STORE=memory
LOCKOUT_STORE=memory
EVENT_BUS=memory

# DynamoDB settings are used when one of the adapter modes above is "dynamo".
RATE_LIMIT_TABLE="turnier-hub-dev-rate-limit"
LOGIN_LOCKOUT_TABLE="turnier-hub-dev-login-lockout"
REALTIME_EVENTS_TABLE="turnier-hub-dev-realtime-events"
EVENT_BUS_POLL_MS=1000

# Optional local endpoint for DynamoDB Local.
# DYNAMODB_ENDPOINT="http://localhost:8000"
