# Entwicklung: .env (nicht committen). Test: .env.test + npm run dev:test / db:push:test
#
# Ohne Authelia vor dem API-Port: Fallback-Identität (nur wenn NODE_ENV nicht "production").
DEV_REMOTE_USER="localdev"
# Optional non-production: jede eingeloggte Identität erhält Admin (Navigation + /api/admin/*).
# DEV_REMOTE_ADMIN=1
DATABASE_URL="file:../../data/dev.db"
DEFAULT_SCHOOL_NAME="defaultSchool"
# Optional: feste Schul-ID für den Katalog (Produktion empfohlen). Ohne Eintrag wird die Schule mit DEFAULT_SCHOOL_NAME verwendet.
# DEFAULT_SCHOOL_ID=""
PORT=3001
# Kommagetrennte Authelia-`Remote-User`-Werte mit Admin-Rechten (nur /api/admin/*).
# ADMIN_REMOTE_USERS="alice,bob"
# Authelia `Remote-Groups` (kommagetrennt): wenn eine Gruppe so heißt → Admin. Leer = Gruppen-Check aus.
# Standardname "admins" wenn Variable fehlt.
# ADMIN_REMOTE_GROUP=admins
# Volle URL zum Authelia-Logout (für SPA „Abmelden“ via GET /api/session → logoutUrl).
# AUTHELIA_LOGOUT_URL="https://auth.example.com/logout"
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
TRUST_PROXY=false
JSON_BODY_LIMIT="100kb"
WS_CONNECT_WINDOW_MS=60000
WS_CONNECT_MAX_PER_IP=30
WS_MESSAGE_WINDOW_MS=10000
WS_MESSAGE_MAX_PER_WINDOW=120
WS_MAX_SUBSCRIPTIONS_PER_CLIENT=50
SECURITY_HTTP_STATUS_WINDOW_MS=60000
SECURITY_HTTP_STATUS_THRESHOLD=50
SECURITY_WS_CONNECTIONS_WINDOW_MS=60000
SECURITY_WS_CONNECTIONS_THRESHOLD=100
