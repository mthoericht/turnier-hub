{
  "references": [{ "path": "../shared" }],
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@turnier-hub/shared": ["../shared/src/index.ts"],
      "@turnier-hub/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*"]
}
