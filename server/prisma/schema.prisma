generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  actorSubject String
  action       String
  targetType   String
  targetId     String
  beforeJson   String?  @db.Text
  afterJson    String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([actorSubject])
}

model School {
  id            String        @id @default(cuid())
  name          String        @unique
  createdAt     DateTime      @default(now())
  schoolClasses SchoolClass[]
  players       Player[]
  tournaments   Tournament[]
}

/// Eine Schulklasse; Spieler verweisen optional darauf.
model SchoolClass {
  id                String   @id @default(cuid())
  schoolId          String
  name              String
  createdBySubject  String
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  players           Player[]
  createdAt         DateTime @default(now())

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Player {
  id                    String                 @id @default(cuid())
  schoolId              String
  createdBySubject      String
  firstName             String
  lastName              String
  schoolClassId         String?
  schoolClass           SchoolClass?           @relation(fields: [schoolClassId], references: [id], onDelete: SetNull)
  school                School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  tournamentMemberships TournamentTeamMember[]
  createdAt             DateTime               @default(now())

  @@index([schoolId])
  @@index([schoolClassId])
}

enum TournamentMode {
  GROUP_KO
  DIRECT_KO
  ROUND_ROBIN
}

model Tournament {
  id                  String                 @id @default(cuid())
  schoolId            String
  createdBySubject    String
  name                String
  sport               String
  mode                TournamentMode         @default(GROUP_KO)
  phase               TournamentPhase        @default(GROUP)
  groupCount          Int                    @default(1)
  advancesPerGroup    Int                    @default(2)
  teamsAreIndividuals Boolean                @default(false)
  school              School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teams               TournamentTeam[]
  teamMembers         TournamentTeamMember[]
  matches             Match[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([schoolId])
}

/// Team vs team (not single-player sides).
model TournamentTeam {
  id           String                 @id @default(cuid())
  tournamentId String
  name         String
  sortOrder    Int                    @default(0)
  groupLabel   String?
  tournament   Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  members      TournamentTeamMember[]
  homeMatches  Match[]                @relation("HomeTeam")
  awayMatches  Match[]                @relation("AwayTeam")

  @@unique([tournamentId, name])
  @@index([tournamentId])
}

enum TournamentPhase {
  GROUP
  ROUND_OF_16
  QUARTER
  SEMI
  FINAL
  COMPLETED
}

/// Player on a team's roster for a tournament.
model TournamentTeamMember {
  id           String         @id @default(cuid())
  tournamentId String
  teamId       String
  playerId     String
  tournament   Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         TournamentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player       Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@unique([teamId, playerId])
  @@index([teamId])
  @@index([tournamentId])
}

enum MatchPhase {
  GROUP
  ROUND_OF_16
  QUARTER
  SEMI
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  PAUSED
  FINISHED
  CANCELLED
}

model Match {
  id                  String          @id @default(cuid())
  tournamentId        String
  phase               MatchPhase
  groupLabel          String?
  roundOrder          Int             @default(0)
  slotIndex           Int             @default(0)
  homeTeamId          String?
  awayTeamId          String?
  homeScore           Int?
  awayScore           Int?
  status              MatchStatus     @default(SCHEDULED)
  matchStartedAt      DateTime?
  totalPausedMs       Int             @default(0)
  pausedAt            DateTime?
  elapsedSnapshotMs   Int?

  tournament          Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  homeTeam            TournamentTeam? @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: SetNull)
  awayTeam            TournamentTeam? @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: SetNull)

  @@index([tournamentId])
  @@index([homeTeamId])
  @@index([awayTeamId])
}
