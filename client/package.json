{
  "name": "client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "STORYBOOK_TESTS=true NODE_ENV=test dotenv -e ../server/.env.test -- vitest run",
    "test:watch": "vitest --config vitest.config.ts ../tests/client/unit",
    "test:unit": "vitest --config vitest.config.ts run ../tests/client/unit",
    "test:integration": "NODE_ENV=test dotenv -e ../server/.env.test -- vitest run ../tests/client/integration",
    "storybook": "storybook dev -p 6006 --config-dir ../tests/client/storybook",
    "build-storybook": "storybook build --config-dir ../tests/client/storybook"
  },
  "dependencies": {
    "@turnier-hub/shared": "file:../shared",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/vue3-vite": "^10.3.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.8",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.1.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.12",
    "storybook": "^10.3.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.2"
  }
}
